#!/bin/sh
. /bin/log_functions.sh

# AdGuardHome服务启动脚本
# 必须以root用户启动，因为需要绑定53端口
# 使用s6-notifyoncheck检测Web管理界面就绪状态
ADGUARDHOME_WEBUI_PORT="${ADGUARDHOME_WEBUI_PORT:-3000}"

log_info "adguardhome" "正在启动 AdGuardHome 服务 (以root用户运行，绑定53端口)..."

# 就绪检测：通过HTTP请求检测Web管理界面是否可访问
exec 2>&1
exec s6-notifyoncheck -d -w 5000 -n 10 \
    -c "curl -sf http://localhost:${ADGUARDHOME_WEBUI_PORT}/ > /dev/null 2>&1" \
    -- AdGuardHome -c /config/adguardhome/AdGuardHome.yaml -w /config/adguardhome
